# ─── Server ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ───────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/intellmeet
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme_in_production

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=changeme_in_production

# ─── JWT ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_REFRESH_EXPIRE=30d

# ─── OpenAI (AI features) ──────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
# Leave empty to use demo/mock mode (no real AI, works offline)
OPENAI_API_KEY=

# ─── Cloudinary (file/avatar uploads) ─────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (optional – password reset, invitations) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@intellmeet.io
FROM_NAME=IntellMeet

# ─── App ───────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Monitoring ────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
SENTRY_DSN=
