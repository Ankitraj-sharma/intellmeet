# Stage 1: Deps
FROM node:20-alpine AS deps
WORKDIR /app
COPY backend/package*.json ./
RUN npm ci --only=production && npm cache clean --force

# Stage 2: Production runner
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 intellmeet
COPY --from=deps /app/node_modules ./node_modules
COPY backend/ .
RUN mkdir -p logs && chown -R intellmeet:nodejs /app
USER intellmeet
EXPOSE 5000
HEALTHCHECK --interval=30s --timeout=10s --retries=3 CMD wget -qO- http://localhost:5000/health || exit 1
CMD ["node", "server.js"]
