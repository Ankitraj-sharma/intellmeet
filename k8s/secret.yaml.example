# Copy to secret.yaml, fill in values, then:
# kubectl apply -f k8s/secret.yaml
# DO NOT commit the real secret.yaml to git!
apiVersion: v1
kind: Secret
metadata:
  name: intellmeet-secrets
  namespace: intellmeet
type: Opaque
stringData:
  JWT_SECRET: "REPLACE_WITH_STRONG_SECRET_32_CHARS"
  JWT_REFRESH_SECRET: "REPLACE_WITH_ANOTHER_STRONG_SECRET"
  MONGODB_URI: "mongodb://admin:password@mongodb-svc:27017/intellmeet?authSource=admin"
  REDIS_URL: "redis://:password@redis-svc:6379"
  OPENAI_API_KEY: "sk-..."
  CLOUDINARY_CLOUD_NAME: "your_cloud"
  CLOUDINARY_API_KEY: "your_key"
  CLOUDINARY_API_SECRET: "your_secret"
